{
  "version": 2,
  "regions": ["gru1"],
  "functions": {
    "backend/server.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "backend/**,EMAIL PORTAL PILOT/**,enterprise/EMAIL enterprise/**"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.js)",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.css)",
      "dest": "/$1"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/tenants",
      "dest": "/tenants.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/usuarios",
      "dest": "/usuarios.html"
    },
    {
      "src": "/global_settings",
      "dest": "/global_settings.html"
    },
    {
      "src": "/billing_plans",
      "dest": "/billing_plans.html"
    },
    {
      "src": "/perfil",
      "dest": "/perfil.html"
    },
    {
      "src": "/primer_acceso",
      "dest": "/primer_acceso.html"
    },
    {
      "src": "/inicio",
      "dest": "/inicio.html"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
